# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Supabase (lead persistence + rate limiting) ───────────────────────────────
# Create free project at supabase.com, then:
# Project Settings → API → copy Project URL and service_role key
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Resend (transactional email) ──────────────────────────────────────────────
# Create free account at resend.com, verify domain, then copy API key
# Also add info@masodikvelemeny.hu as a verified sender
RESEND_API_KEY=re_your-key-here

# ── Local dev ─────────────────────────────────────────────────────────────────
PORT=10000
